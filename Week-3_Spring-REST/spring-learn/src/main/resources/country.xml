<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        bean tag     - defines a Spring managed object
        id attribute - unique name to get bean from context
        class attribute - fully qualified class name
        property tag - sets a value on bean property
        name attribute - property name in Java class
        value attribute - value to assign
    -->
    <bean id="country" class="com.cognizant.springlearn.Country">
        <property name="code" value="IN"/>
        <property name="name" value="India"/>
    </bean>

</beans>
